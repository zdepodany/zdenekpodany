  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.zdenekpodany.cz"
        }
      ],
      "destination": "https://zdenekpodany.cz/$1",
      "permanent": true
    },
    {
      "source": "/tvorba-webu-znojmo.html",
      "destination": "/tvorba-webu-znojmo",
      "permanent": true
    },
    {
      "source": "/vseobecne-obchodni-podminky.html",
      "destination": "/vseobecne-obchodni-podminky",
      "permanent": true
    },
    {
      "source": "/zasady-ochrany-osobnich-udaju.html",
